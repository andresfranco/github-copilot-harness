# Database
DATABASE_URL=postgresql+asyncpg://snowflake_user:snowflake_pass@localhost:5432/snowflake_keys

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-valid-fernet-key-base64urlsafe

# JWT settings
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
VITE_API_URL=http://localhost:8000
